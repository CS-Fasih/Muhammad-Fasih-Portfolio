# MongoDB Atlas application connection string
MONGODB_URI=mongodb+srv://<db-user>:<db-password>@<cluster-host>/portfolio?retryWrites=true&w=majority

# Single-administrator authentication
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD_HASH=$2b$12$replace_with_a_real_bcrypt_hash
JWT_SECRET=replace-with-a-long-random-secret

# Cloudinary product environment (server-side; never expose the API secret)
CLOUDINARY_CLOUD_NAME=replace-with-your-cloud-name
CLOUDINARY_API_KEY=replace-with-your-api-key
CLOUDINARY_API_SECRET=replace-with-your-api-secret

# Optional: required only for the existing portfolio chatbot
GROQ_API_KEY=replace-with-your-groq-api-key
